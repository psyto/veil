{
  "name": "Fabrknt Privacy",
  "slug": "fabrknt-privacy",
  "version": "0.1.0",
  "description": "Chain-agnostic privacy primitives. NaCl encryption, Shamir secret sharing, encrypted order payloads, payload serialization, and ZK compression via Light Protocol.",
  "type": "rest",
  "author": "Fabrknt",
  "category": "privacy",
  "support": {
    "email": "support@fabrknt.com",
    "url": "https://fabrknt.com/support"
  },
  "repository": "https://github.com/psyto/veil",
  "healthcheck": "/healthcheck",
  "authentication": "basic",
  "chains": [
    {
      "id": "solana",
      "name": "Solana"
    },
    {
      "id": "ethereum",
      "name": "Ethereum"
    }
  ],
  "networks": {
    "solana": ["mainnet-beta", "devnet", "testnet"],
    "ethereum": ["mainnet", "goerli"]
  },
  "provisioning": {
    "provision": "POST /provision",
    "update": "PUT /update",
    "deactivate": "DELETE /deactivate_endpoint",
    "deprovision": "DELETE /deprovision"
  },
  "plans": [
    {
      "id": "starter",
      "name": "Starter",
      "price": 0,
      "description": "Stateless privacy primitives: encryption, secret sharing, payload serialization, and compression estimation.",
      "rate_limit": {
        "requests_per_minute": 100
      },
      "features": [
        "NaCl box encryption/decryption",
        "Broadcast encryption for multiple recipients",
        "Keypair generation, derivation, and key format conversion",
        "Encrypted data validation",
        "Shamir secret sharing (split/combine/verify)",
        "Encrypted order payloads with validation",
        "Payload serialization (SWAP_ORDER, RWA_ASSET, RWA_ACCESS_GRANT)",
        "ZK compression cost estimation"
      ]
    },
    {
      "id": "pro",
      "name": "Pro",
      "price": 49,
      "description": "All Starter features plus on-chain ZK compression via Light Protocol and priority support.",
      "rate_limit": {
        "requests_per_minute": 500
      },
      "features": [
        "All Starter features",
        "ZK data compression via Light Protocol",
        "ZK data decompression",
        "Uses provisioned QuickNode endpoint for RPC calls",
        "Priority support"
      ]
    }
  ],
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/keypair/generate",
      "description": "Generate a random NaCl X25519 encryption keypair",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/keypair/derive",
      "description": "Derive a deterministic encryption keypair from a 32-byte seed",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/encrypt",
      "description": "Encrypt plaintext using NaCl box (Curve25519-XSalsa20-Poly1305)",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/decrypt",
      "description": "Decrypt NaCl box ciphertext",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/crypto/encrypt-multiple",
      "description": "Encrypt plaintext for multiple recipients (up to 50)",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/crypto/validate",
      "description": "Validate encrypted data structure",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/crypto/key-convert",
      "description": "Convert key between base64, hex (EVM), and base58 (Solana) formats",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/threshold/split",
      "description": "Split a secret into M-of-N Shamir shares",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/threshold/combine",
      "description": "Combine Shamir shares to recover the original secret",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/threshold/verify",
      "description": "Verify Shamir shares are consistent with a given threshold",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/orders/encrypt",
      "description": "Encrypt a swap order payload for MEV-protected submission",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/orders/decrypt",
      "description": "Decrypt an encrypted swap order payload",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/orders/validate",
      "description": "Validate encrypted order payload structure",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/payload/serialize",
      "description": "Serialize structured data to binary using a named or custom schema",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/payload/deserialize",
      "description": "Deserialize binary data back to structured fields",
      "plan": "starter"
    },
    {
      "method": "GET",
      "path": "/v1/compression/estimate",
      "description": "Estimate ZK compression cost savings for a given data size",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/compression/compress",
      "description": "Compress data on-chain via Light Protocol ZK compression",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/compression/decompress",
      "description": "Decompress Light Protocol ZK-compressed data",
      "plan": "pro"
    }
  ]
}
